# Dependencies (huge folder, installs via npm ci)
node_modules/
/.pnp
.pnp.js

# Environment files (SECRETS - NEVER upload!)
.env
.env.local
.env.*.local
.env.production

# Build output (generated by npm run build, not needed in repo)
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Uploads (user files, not part of code)
uploads/

# IDE settings (personal, not needed)
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS junk files
.DS_Store
Thumbs.db
desktop.ini

# Testing
coverage/
.nyc_output/

# Prisma migrations - MUST be committed for deployment!
# prisma/migrations/  <-- REMOVED: migrations must be in repo for prisma migrate deploy

# Docker backups
backups/

# Misc temp files
.cache/
.temp/
tmp/

# Deployment agent (local tool, not part of project)
deploy-agent/

# Extra files / mobile app (huge, not needed in Docker build)
EXTRA/
mobile-app/
*.zip

# Platform-specific generated files (auto-created by deploy agent)
render.yaml
vercel.json
fly.toml

# AI/Editor config (personal settings)
.continue/
.qodo/
.qwen/
.roo/

# Windows reserved device names
/nul
nul

# Accidental nested repos
MY\ PROJECT*/

# Android local SDK path (machine-specific, not in repo)
/local.properties
local.properties

.envorg
.envorg.txt
