# ============================================
# BizzAuto CRM - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ==================== APP CORE ====================
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ==================== DATABASE (PostgreSQL) ====================
DATABASE_URL=postgresql://bizzauto:bizzauto_password@localhost:5432/bizzauto_db
POSTGRES_USER=bizzauto
POSTGRES_PASSWORD=bizzauto_password
POSTGRES_DB=bizzauto_db

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ==================== AUTH / JWT ====================
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=your-aes-256-encryption-key-64-hex-chars

# ==================== SUPER ADMIN ====================
# Required for creating the first super admin via API
# Generate with: openssl rand -hex 32
# Usage: curl -X POST http://localhost:4000/api/auth/create-super-admin
#   -H "Content-Type: application/json"
#   -H "x-bootstrap-token: YOUR_TOKEN_HERE"
#   -d '{"email": "admin@example.com", "password": "Admin123!", "name": "Super Admin"}'
SUPER_ADMIN_BOOTSTRAP_TOKEN=your-super-admin-bootstrap-token-here

# ==================== CORS & URLs ====================
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:4000

# ==================== SMTP / EMAIL ====================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# SMTP_FROM="BizzAuto CRM <noreply@bizzautoai.com>"
# APP_NAME=BizzAuto
# APP_URL=http://localhost:4000

# ==================== AI SERVICES ====================
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# GROK_API_KEY=xai-your-grok-api-key
# REPLICATE_API_KEY=r8-your-replicate-api-key
# OLLAMA_BASE_URL=http://localhost:11434

# ==================== WHATSAPP (Evolution API) ====================
# Evolution API is an open-source WhatsApp Web API (https://github.com/EvolutionAPI/evolution-api)
# It runs as a Docker service alongside the app.
# Generate an API key: openssl rand -hex 32
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key-min-32-chars
EVOLUTION_INSTANCE_NAME=bizzauto
# Whitelist IPs that can access Evolution API without API key (optional, comma-separated)
# EVOLUTION_WHITELIST_IPS="127.0.0.1,::1"
# Separate database/schema URL for Evolution API (optional — tables use different naming, no conflict)
# If not set, Evolution API uses the same DATABASE_URL (its tables: Instances, Messages, Chats
# vs app tables: wa_instances, wa_messages, wa_chats — no conflict)
# For separate schema in same database (recommended):
#   EVOLUTION_DATABASE_URL=postgresql://postgres:pass@host:5432/postgres?options=-c%20search_path=evolution
# Webhook URL that Evolution API calls for incoming messages (defaults to FRONTEND_URL + /api/evolution/webhook)
# EVOLUTION_WEBHOOK_URL=https://bizzautoai.com/api/evolution/webhook

# ==================== META / FACEBOOK (WhatsApp Business) ====================
# META_APP_ID=your-meta-app-id
# WHATSAPP_REDIRECT_URL=http://localhost:4000/api/whatsapp/callback

# ==================== GOOGLE ====================
# Google OAuth Client ID & Secret (from Google Cloud Console > APIs & Services > Credentials)
# Required for: Sign-in with Google, Google account linking in Settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI for Google OAuth login/signup — must match the redirect URI in Google Cloud Console
# For local dev: http://localhost:4000/api/auth/google/callback
# For production: https://bizzautoai.com/api/auth/google/callback
GOOGLE_AUTH_REDIRECT_URL=http://localhost:4000/api/auth/google/callback
# Redirect URI for Google Business Profile OAuth (separate OAuth flow)
# For local dev: http://localhost:4000/api/google-business/auth/callback
# For production: https://bizzautoai.com/api/google-business/auth/callback
GOOGLE_BUSINESS_REDIRECT_URL=http://localhost:4000/api/google-business/auth/callback
# Redirect URI for Google Sheets integration (separate OAuth flow)
# GOOGLE_SHEETS_REDIRECT_URL=http://localhost:4000/api/integrations/google-sheets/callback

# ==================== APPLE ====================
# APPLE_CLIENT_ID=com.your.app

# ==================== RAZORPAY (Payments) ====================
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# ==================== SENTRY (Error Tracking) ====================
# SENTRY_DSN=https://your-sentry-dsn

# ==================== UPI ====================
# UPI_VPA=bizzauto@upi

# ==================== n8n WORKFLOW AUTOMATION ====================
N8N_URL=http://n8n:5678
# App → n8n outgoing auth: API key created in n8n UI (Settings > n8n API)
# Used by the app to call n8n REST API (e.g., fetch workflows)
N8N_APP_API_KEY=your-app-to-n8n-api-key
# n8n → App incoming auth: API key n8n workflows send via x-n8n-api-key header
# Used by n8n to authenticate calls to the app's API endpoints
N8N_API_KEY=your-n8n-to-app-api-key-min-32-chars
N8N_PASSWORD=your-n8n-admin-password
N8N_HOST=localhost
N8N_PROTOCOL=http
# N8N_WEBHOOK_URL=http://your-public-url:5678/
N8N_ENCRYPTION_KEY=your-n8n-encryption-key
N8N_USER_MANAGEMENT_JWT_SECRET=your-n8n-jwt-secret

# ==================== GRAFANA (Monitoring) ====================
# GRAFANA_PASSWORD=admin123
