          "refId": "C"
        },
        {
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[1h]))",
          "legendFormat": "5xx",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
