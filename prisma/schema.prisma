generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  name                 String?
  password             String?
  phone                String?
  role                 Role              @default(OWNER)
  businessId           String?
  emailVerified        DateTime?
  image                String?
  avatar               String?
  isActive             Boolean           @default(true)
  isVerified           Boolean           @default(false)
  lastLoginAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  twoFactorSecret      String?
  twoFactorEnabled     Boolean           @default(false)
  twoFactorBackupCodes String?
  resetToken           String?
  csrfToken            String?
  csrfTokenExpiresAt   DateTime?
  appleId              String?           @unique
  googleId             String?           @unique
  resetTokenExpiresAt  DateTime?
  tokenExpiry          DateTime?
  verificationToken    String?
  aiContents           AIContent[]
  agencies             Agency[]
  notifications        Notification[]
  platformReferral     PlatformReferral?
  themePref            ThemePreference?
  business             Business?         @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([appleId])
  @@index([email])
  @@index([role])
}

model Business {
  id                     String                  @id @default(cuid())
  name                   String
  type                   String
  phone                  String?
  email                  String?
  city                   String?
  state                  String?
  country                String                  @default("India")
  address                String?
  website                String?
  logoUrl                String?
  brandColors            Json?
  timezone               String                  @default("Asia/Kolkata")
  contactsLimit          Int                     @default(500)
  messagesLimit          Int                     @default(1000)
  usersLimit             Int                     @default(1)
  plan                   Plan                    @default(FREE)
  planStartedAt          DateTime?
  planExpiresAt          DateTime?
  razorpaySubId          String?
  razorpayOrderId        String?
  wabaId                 String?
  waPhoneNumberId        String?
  waAccessToken          String?
  waWebhookSecret        String?
  waPhoneNumber          String?
  fbPageId               String?
  fbAccessToken          String?
  igUserId               String?
  igAccessToken          String?
  linkedinPageId         String?
  linkedinAccessToken    String?
  twitterUserId          String?
  twitterAccessToken     String?
  gbpAccessToken         String?
  gbpAccountId           String?
  gbpLocationId          String?
  autoReplyEnabled       Boolean                 @default(false)
  autoReplyMessage       String?
  businessHours          Json?
  totalMessages          Int                     @default(0)
  totalContacts          Int                     @default(0)
  aiCreditsUsed          Int                     @default(0)
  aiCreditsLimit         Int                     @default(100)
  aiCreditsPurchased     Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  admissionCompleted     Boolean                 @default(false)
  onboardingCompleted   Boolean                 @default(false)
  dograhApiKey           String?
  dograhApiUrl           String?
  dograhDefaultAgentId   Int?
  dograhEnabled          Boolean                 @default(false)
  dograhWebhookSecret    String?
  gbpAutoPostDays        Json                    @default("[\"monday\", \"tuesday\", \"wednesday\", \"thursday\", \"friday\"]")
  gbpAutoPostEnabled     Boolean                 @default(false)
  gbpAutoPostLastPosted  DateTime?
  gbpAutoPostTemplates   Json                    @default("[]")
  gbpAutoPostTime        String                  @default("09:00")
  gbpAutoPostTimezone    String                  @default("Asia/Kolkata")
  gbpRefreshToken        String?
  gbpTokenExpiry         DateTime?
  leadWebhookSecret      String?
  telephonyProvider      String                  @default("twilio")
  youtubeAccessToken     String?
  youtubeChannelId       String?
  aiFollowUps            AIFollowUp[]
  activities             Activity[]
  analyticsIntegration   AnalyticsIntegration?
  apiKeys                ApiKey[]
  appointments           Appointment[]
  appointmentReminders   AppointmentReminder[]
  auditLogs              AuditLog[]
  autoReplies            AutoReply[]
  automationRules        AutomationRule[]
  autopilotSettings      AutopilotSettings?
  blogCategories         BlogCategory[]
  blogPosts              BlogPost[]
  callLogs               CallLog[]
  campaigns              Campaign[]
  carts                  Cart[]
  cartRecoveries         CartRecovery[]
  chatbotFlows           ChatbotFlow[]
  clientPortals          ClientPortal[]
  contacts               Contact[]
  coupons                Coupon[]
  courses                Course[]
  customFields           CustomField[]
  customerSegments       CustomerSegment[]
  discountRules          DiscountRule[]
  documents              Document[]
  documentTemplates      DocumentTemplate[]
  dripCampaigns          DripCampaign[]
  eCommerceStore         ECommerceStore?
  emailLists             EmailList[]
  emailTemplates         EmailTemplate[]
  flashSales             FlashSale[]
  funnels                Funnel[]
  giftCards              GiftCard[]
  goals                  Goal[]
  integrations           Integration[]
  invoices               Invoice[]
  leadFinderSearches     LeadFinderSearch[]
  leadScores             LeadScore[]
  ledgerEntries          LedgerEntry[]
  liveChatSessions       LiveChatSession[]
  liveChatWidget         LiveChatWidget?
  lowStockAlerts         LowStockAlert[]
  loyaltyPoints          LoyaltyPoints[]
  loyaltyProgram         LoyaltyProgram?
  loyaltyRewards         LoyaltyReward[]
  messageTemplates       MessageTemplate[]
  newEmailTemplates      NewEmailTemplate[]
  orderNotifications     OrderNotification[]
  outreachCampaigns      OutreachCampaign[]
  outreachLogs           OutreachLog[]
  paymentLinks           PaymentLink[]
  pipelines              Pipeline[]
  posts                  Post[]
  posterTemplates        PosterTemplate[]
  products               Product[]
  productBundles         ProductBundle[]
  productReviews         ProductReview[]
  referrals              Referral[]
  referralProgram        ReferralProgram?
  returnRequests         ReturnRequest[]
  reviews                Review[]
  reviewRequests         ReviewRequest[]
  reviewRequestCampaigns ReviewRequestCampaign[]
  smsCampaigns           SMSCampaign[]
  smsMessages            SMSMessage[]
  scheduledMessages      ScheduledMessage[]
  shippingRules          ShippingRule[]
  sizeGuides             SizeGuide[]
  stockAlerts            StockAlert[]
  storeTheme             StoreTheme?
  storeTranslations      StoreTranslation[]
  subAccounts            SubAccount[]
  subscriptions          Subscription[]
  subscriptionPlans      SubscriptionPlan[]
  supportTickets         SupportTicket[]
  surveys                Survey[]
  triggerLinks           TriggerLink[]
  users                  User[]
  videoMeetings          VideoMeeting[]
  wallet                 Wallet?
  webhooks               Webhook[]
  whatsappCatalogs       WhatsAppCatalog[]
  whiteLabel             WhiteLabel?
  wingsStore             WingsStore[]
  wishlists              Wishlist[]
  workflows              Workflow[]
  workflowExecutions     WorkflowExecution[]
  workflowRuns           WorkflowRun[]

  @@index([plan])
}

model Subscription {
  id                     String    @id @default(cuid())
  businessId             String
  plan                   Plan
  status                 String
  startDate              DateTime
  endDate                DateTime?
  razorpaySubscriptionId String?
  razorpayOrderId        String?
  razorpayPaymentId      String?
  razorpaySubId          String?
  amount                 Int
  currency               String    @default("INR")
  interval               String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  cancelledBy            String?
  metadata               Json?
  paymentMethodId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  business               Business  @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([status])
}

model Contact {
  id                   String                 @id @default(cuid())
  businessId           String
  name                 String
  phone                String?
  email                String?
  company              String?
  title                String?
  designation          String?
  city                 String?
  state                String?
  source               String                 @default("manual")
  sourceId             String?
  pipelineId           String?
  stageId              String?
  stageName            String?
  tags                 String[]               @default([])
  customFields         Json?
  metadata             Json?
  dealValue            Float                  @default(0)
  dealStage            String?
  whatsappOptIn        Boolean                @default(false)
  whatsappBlocked      Boolean                @default(false)
  waProfilePic         String?
  waLastMessageAt      DateTime?
  lastMessageAt        DateTime?
  lastActivity         DateTime?
  status               String                 @default("active")
  stage                String?
  assignedTo           String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  emailOptIn           Boolean                @default(false)
  leadFinderData       Json?
  leadFinderScore      Int?
  leadFinderSource     String?
  aiFollowUps          AIFollowUp[]
  activities           Activity[]
  appointments         Appointment[]
  appointmentReminders AppointmentReminder[]
  callLogs             CallLog[]
  cartRecoveries       CartRecovery[]
  business             Business               @relation(fields: [businessId], references: [id])
  pipeline             Pipeline?              @relation(fields: [pipelineId], references: [id])
  addresses            CustomerAddress[]
  subscriptions        CustomerSubscription[]
  documents            Document[]
  dripQueueItems       DripQueue[]
  leadScores           LeadScore[]
  ledgerEntries        LedgerEntry[]
  loyaltyPoints        LoyaltyPoints[]
  messages             Message[]
  orders               Order[]
  outreachLogs         OutreachLog[]
  productReviews       ProductReview[]
  pushSubscriptions    PushSubscription[]
  referredUsers        Referral[]             @relation("Referee")
  referredBy           Referral[]             @relation("Referrer")
  returnRequests       ReturnRequest[]
  scheduledMessages    ScheduledMessage[]
  segmentMembers       SegmentMember[]
  stockAlerts          StockAlert[]
  supportTickets       SupportTicket[]
  wishlists            Wishlist[]

  @@unique([businessId, phone])
  @@unique([businessId, email])
  @@index([businessId])
  @@index([businessId, source])
  @@index([businessId, createdAt])
  @@index([businessId, lastMessageAt])
  @@index([source])
  @@index([tags])
}

model Pipeline {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  description String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[]
  business    Business  @relation(fields: [businessId], references: [id])
  stages      Stage[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Stage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int
  color      String?
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}

model Activity {
  id          String    @id @default(cuid())
  businessId  String
  contactId   String?
  type        String
  title       String
  description String?
  content     String?
  metadata    Json?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("medium")
  dealValue   Float?
  stageFrom   String?
  stageTo     String?
  createdBy   String
  createdAt   DateTime  @default(now())
  business    Business  @relation(fields: [businessId], references: [id])
  contact     Contact?  @relation(fields: [contactId], references: [id])

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, type])
  @@index([businessId, createdAt])
  @@index([contactId])
  @@index([type])
}

model Message {
  id               String    @id @default(cuid())
  contactId        String?
  businessId       String?   @default(cuid())
  waMessageId      String?
  direction        String
  type             String
  content          String
  mediaUrl         String?
  mediaType        String?
  mediaSize        Int?
  mediaName        String?
  templateName     String?
  templateLanguage String?
  templateParams   Json?
  templateVars     Json?
  status           String    @default("pending")
  statusTimestamp  DateTime?
  statusUpdatedAt  DateTime?
  errorCode        String?
  errorMessage     String?
  error            String?
  campaignId       String?
  interactiveType  String?
  metadata         Json?
  replyToMessageId String?
  replyContext     Json?
  createdAt        DateTime  @default(now())
  campaign         Campaign? @relation(fields: [campaignId], references: [id])
  contact          Contact?  @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model MessageTemplate {
  id           String    @id @default(cuid())
  businessId   String
  name         String
  language     String    @default("en")
  category     String    @default("UTILITY")
  components   Json
  status       String    @default("PENDING")
  waTemplateId String?
  waStatus     String?
  usageCount   Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  business     Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
}

model Campaign {
  id             String      @id @default(cuid())
  businessId     String
  name           String
  type           String
  status         String      @default("draft")
  segmentId      String?
  filters        Json?
  contactIds     String[]
  targetTags     String[]
  targetFilters  Json?
  targetContacts Int         @default(0)
  targetCount    Int         @default(0)
  templateId     String?
  templateName   String?
  templateVars   Json?
  content        Json
  dripSteps      Json?
  scheduledAt    DateTime?
  startedAt      DateTime?
  sentAt         DateTime?
  completedAt    DateTime?
  totalContacts  Int         @default(0)
  totalSent      Int         @default(0)
  sent           Int         @default(0)
  delivered      Int         @default(0)
  read           Int         @default(0)
  clicked        Int         @default(0)
  failed         Int         @default(0)
  totalDelivered Int         @default(0)
  totalRead      Int         @default(0)
  totalReplied   Int         @default(0)
  totalFailed    Int         @default(0)
  errors         Json[]
  createdBy      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  business       Business    @relation(fields: [businessId], references: [id])
  dripQueueItems DripQueue[]
  messages       Message[]

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
  @@index([businessId, status])
}

model Appointment {
  id           String   @id @default(cuid())
  businessId   String
  contactId    String
  title        String
  description  String?
  service      String?
  startTime    DateTime
  endTime      DateTime
  status       String   @default("pending")
  location     String?
  isOnline     Boolean  @default(false)
  meetingLink  String?
  meetingUrl   String?
  reminderSent Boolean  @default(false)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id])
  contact      Contact  @relation(fields: [contactId], references: [id])

  @@index([businessId])
  @@index([contactId])
  @@index([startTime])
  @@index([businessId, status])
  @@index([contactId, startTime])
}

model Product {
  id               String            @id @default(cuid())
  businessId       String
  name             String
  description      String?
  price            Float
  compareAtPrice   Float?
  sku              String?
  barcode          String?
  quantity         Int               @default(0)
  trackInventory   Boolean           @default(true)
  images           String[]
  mainImage        String?
  category         String?
  tags             String[]
  isActive         Boolean           @default(true)
  status           String            @default("active")
  shopifyId        String?
  wooCommerceId    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bundleItems      BundleItem[]
  cartItems        CartItem[]
  LowStockAlert    LowStockAlert[]
  orders           OrderItem[]
  priceHistory     PriceHistory[]
  business         Business          @relation(fields: [businessId], references: [id])
  reviews          ProductReview[]
  variants         ProductVariant[]
  productVideos    ProductVideo[]
  recentlyViewed   RecentlyViewed[]
  stockAlerts      StockAlert[]
  subscriptionPlan SubscriptionPlan?
  wishlist         Wishlist[]

  @@index([businessId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  options   Json
  price     Float?
  sku       String?
  quantity  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id                 String              @id @default(cuid())
  businessId         String
  contactId          String
  orderNumber        String              @unique
  status             String              @default("pending")
  paymentStatus      String              @default("pending")
  subtotal           Float
  taxAmount          Float               @default(0)
  shippingAmount     Float               @default(0)
  discountAmount     Float               @default(0)
  total              Float
  shippingAddress    Json?
  gateway            String?
  gatewayData        Json?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bundleId           String?
  bundle             ProductBundle?      @relation(fields: [bundleId], references: [id])
  contact            Contact             @relation(fields: [contactId], references: [id])
  items              OrderItem[]
  orderNotifications OrderNotification[]
  returnRequest      ReturnRequest?

  @@index([businessId])
  @@index([contactId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  name      String
  quantity  Int
  price     Float
  total     Float
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Cart {
  id         String     @id @default(cuid())
  businessId String
  contactId  String
  status     String     @default("active")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  business   Business   @relation(fields: [businessId], references: [id])
  items      CartItem[]

  @@unique([businessId, contactId])
  @@index([businessId])
  @@index([contactId])
}

model CartItem {
  id           String   @id @default(cuid())
  cartId       String
  productId    String
  variantId    String?
  variantName  String?
  variantPrice Float?
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model ProductReview {
  id            String   @id @default(cuid())
  businessId    String
  productId     String
  contactId     String?
  customerName  String
  customerEmail String?
  rating        Int
  title         String?
  comment       String?
  isVerified    Boolean  @default(false)
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  business      Business @relation(fields: [businessId], references: [id])
  contact       Contact? @relation(fields: [contactId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([businessId])
  @@index([rating])
}

model Wishlist {
  id         String   @id @default(cuid())
  businessId String
  contactId  String
  productId  String
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
  contact    Contact  @relation(fields: [contactId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([contactId, productId])
  @@index([contactId])
  @@index([productId])
}

model StockAlert {
  id            String    @id @default(cuid())
  businessId    String
  productId     String
  contactId     String?
  customerEmail String?
  customerPhone String?
  status        String    @default("pending")
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  business      Business  @relation(fields: [businessId], references: [id])
  contact       Contact?  @relation(fields: [contactId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([businessId])
  @@index([status])
}

model ShippingRule {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  minOrderAmount  Float    @default(0)
  maxOrderAmount  Float?
  shippingFee     Float    @default(0)
  freeAbove       Float?
  pincodePrefixes String[]
  states          String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model ProductBundle {
  id            String       @id @default(cuid())
  businessId    String
  name          String
  description   String?
  discountType  String       @default("percentage")
  discountValue Float        @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  items         BundleItem[]
  orders        Order[]
  business      Business     @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model BundleItem {
  id        String        @id @default(cuid())
  bundleId  String
  productId String
  quantity  Int           @default(1)
  bundle    ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])

  @@index([bundleId])
  @@index([productId])
}

model FlashSale {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  discountType  String   @default("percentage")
  discountValue Float
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean  @default(true)
  productIds    String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  business      Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([startsAt, endsAt])
}

model GiftCard {
  id                 String    @id @default(cuid())
  businessId         String
  code               String    @unique
  amount             Float
  balance            Float
  purchaserContactId String?
  recipientName      String?
  recipientEmail     String?
  recipientPhone     String?
  message            String?
  status             String    @default("active")
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  business           Business  @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([code])
  @@index([status])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  contactId String
  productId String
  viewCount Int      @default(1)
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([contactId, productId])
  @@index([contactId])
  @@index([viewedAt])
}

model ProductComparison {
  id         String   @id @default(cuid())
  sessionId  String
  productIds String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sessionId])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  contactId  String
  businessId String
  label      String   @default("Home")
  name       String
  phone      String
  email      String?
  address    String
  city       String
  state      String
  pincode    String
  country    String   @default("India")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contact    Contact  @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([businessId])
}

model ReturnRequest {
  id           String   @id @default(cuid())
  businessId   String
  orderId      String   @unique
  contactId    String?
  reason       String
  description  String?
  status       String   @default("pending")
  refundAmount Float?
  refundMethod String?
  images       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id])
  contact      Contact? @relation(fields: [contactId], references: [id])
  order        Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([businessId])
  @@index([status])
}

model SubscriptionPlan {
  id             String                 @id @default(cuid())
  businessId     String
  name           String
  description    String?
  interval       String                 @default("monthly")
  price          Float
  productId      String?                @unique
  isActive       Boolean                @default(true)
  maxSubscribers Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  subscriptions  CustomerSubscription[]
  business       Business               @relation(fields: [businessId], references: [id])
  product        Product?               @relation(fields: [productId], references: [id])

  @@index([businessId])
}

model CustomerSubscription {
  id              String           @id @default(cuid())
  businessId      String
  planId          String
  contactId       String
  status          String           @default("active")
  nextBillingDate DateTime?
  lastBillingDate DateTime?
