generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & TENANCY ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  googleId      String?   @unique
  appleId       String?   @unique
  name          String?
  password      String?
  phone         String?
  role          Role      @default(OWNER)
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id])
  emailVerified DateTime?
  image         String?
  avatar        String?
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false) // <--- हा नवीन कॉलम जोडला आहे
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 2FA Fields
  twoFactorSecret      String?
  twoFactorEnabled     Boolean @default(false)
  twoFactorBackupCodes String?

  // CSRF Token
  csrfToken          String?
  csrfTokenExpiresAt DateTime?

  // Password Reset Token
  resetToken          String?
  resetTokenExpiresAt DateTime?

  // Email Verification Token
  verificationToken String?
  tokenExpiry       DateTime?

  notifications Notification[]
  themePref     ThemePreference?
  aiContents    AIContent[]
  agencies      Agency[]
  platformReferral PlatformReferral?

  @@index([businessId])
  @@index([appleId])
  @@index([email])
  @@index([role])
}

model Business {
  id          String  @id @default(cuid())
  name        String
  type        String
  phone       String?
  email       String?
  city        String?
  state       String?
  country     String  @default("India")
  address     String?
  website     String?
  logoUrl     String?
  brandColors Json?
  timezone    String  @default("Asia/Kolkata")

  // --- LIMITS (हे कॉलम्स तुमच्या सीडिंगसाठी महत्त्वाचे आहेत) ---
  contactsLimit Int @default(500)
  messagesLimit Int @default(1000)
  usersLimit    Int @default(1)

  // Subscription
  plan              Plan      @default(FREE)
  planStartedAt     DateTime?
  planExpiresAt     DateTime?
  razorpaySubId     String?
  razorpayOrderId   String?

  // Admission Form
  admissionCompleted Boolean @default(false)

  // WhatsApp Config
  wabaId          String?
  waPhoneNumberId String?
  waAccessToken   String?
  waWebhookSecret String?
  waPhoneNumber   String?

  // Social Media
  fbPageId            String?
  fbAccessToken       String?
  igUserId            String?
  igAccessToken       String?
  linkedinPageId      String?
  linkedinAccessToken String?
  twitterUserId       String?
  twitterAccessToken  String?
  youtubeChannelId    String?
  youtubeAccessToken  String?

  // Google Business Profile
  gbpAccessToken  String?
  gbpRefreshToken String?
  gbpAccountId    String?
  gbpLocationId   String?
  gbpTokenExpiry  DateTime?

  // GBP Auto-Post Configuration
  gbpAutoPostEnabled     Boolean @default(false)
  gbpAutoPostTime        String  @default("09:00") // HH:mm format
  gbpAutoPostTimezone    String  @default("Asia/Kolkata")
  gbpAutoPostDays        Json    @default("[\"monday\",\"tuesday\",\"wednesday\",\"thursday\",\"friday\"]") // Days to post
  gbpAutoPostTemplates   Json    @default("[]") // Array of post templates
  gbpAutoPostLastPosted  DateTime?

  // Webhook Security
  leadWebhookSecret String?

  // Auto Reply
  autoReplyEnabled Boolean @default(false)
  autoReplyMessage String?
  businessHours    Json?

  // Legacy fields
  totalMessages Int @default(0)
  totalContacts Int @default(0)

  // AI Credits
  aiCreditsUsed      Int @default(0)
  aiCreditsLimit     Int @default(100)
  aiCreditsPurchased Int @default(0)

  // Dograh Voice AI
  dograhApiKey         String?
  dograhApiUrl         String?
  dograhEnabled        Boolean @default(false)
  dograhWebhookSecret  String?
  dograhDefaultAgentId Int?
  telephonyProvider    String  @default("twilio") // "twilio" | "plivo" | "browser_only"

  // Relations
  users                  User[]
  contacts               Contact[]
  ledgerEntries          LedgerEntry[]
  coupons                Coupon[]
  pipelines              Pipeline[]
  campaigns              Campaign[]
  appointments           Appointment[]
  documents              Document[]
  products               Product[]
  posts                  Post[]
  reviews                Review[]
  integrations           Integration[]
  activities             Activity[]
  wingsStore             WingsStore[]
  eCommerceStore         ECommerceStore?
  posterTemplates        PosterTemplate[]
  whiteLabel             WhiteLabel?
  messageTemplates       MessageTemplate[]
  documentTemplates      DocumentTemplate[]
  autopilotSettings      AutopilotSettings?
  subscriptions          Subscription[]
  auditLogs              AuditLog[]
  automationRules        AutomationRule[]
  workflowRuns           WorkflowRun[]
  invoices               Invoice[]
  leadScores             LeadScore[]
  webhooks               Webhook[]
  apiKeys                ApiKey[]
  chatbotFlows           ChatbotFlow[]
  emailTemplates         EmailTemplate[]
  dripCampaigns          DripCampaign[]
  emailLists             EmailList[]
  scheduledMessages      ScheduledMessage[]
  autoReplies            AutoReply[]
  // New feature relations
  workflows              Workflow[]
  workflowExecutions     WorkflowExecution[]
  funnels                Funnel[]
  surveys                Survey[]
  courses                Course[]
  triggerLinks           TriggerLink[]
  clientPortals          ClientPortal[]
  customFields           CustomField[]
  blogPosts              BlogPost[]
  blogCategories         BlogCategory[]
  paymentLinks           PaymentLink[]
  reviewRequests         ReviewRequest[]
  reviewRequestCampaigns ReviewRequestCampaign[]
  subAccounts            SubAccount[]
  liveChatSessions       LiveChatSession[]
  liveChatWidget         LiveChatWidget?
  smsMessages            SMSMessage[]
  smsCampaigns           SMSCampaign[]
  cartRecoveries         CartRecovery[]
  appointmentReminders   AppointmentReminder[]
  loyaltyProgram         LoyaltyProgram?
  loyaltyPoints          LoyaltyPoints[]
  loyaltyRewards         LoyaltyReward[]
  referralProgram        ReferralProgram?
  referrals              Referral[]
  aiFollowUps            AIFollowUp[]
  whatsappCatalogs       WhatsAppCatalog[]
  videoMeetings          VideoMeeting[]
  supportTickets         SupportTicket[]
  callLogs               CallLog[]
  wallet                 Wallet?
  carts                  Cart[]
  productReviews         ProductReview[]
  wishlists              Wishlist[]
  stockAlerts            StockAlert[]
  shippingRules          ShippingRule[]
  productBundles         ProductBundle[]
  flashSales             FlashSale[]
  giftCards              GiftCard[]
  returnRequests         ReturnRequest[]
  subscriptionPlans      SubscriptionPlan[]
  storeTheme             StoreTheme?
  sizeGuides             SizeGuide[]
  newEmailTemplates      NewEmailTemplate[]
  customerSegments       CustomerSegment[]
  lowStockAlerts         LowStockAlert[]
  storeTranslations      StoreTranslation[]
  analyticsIntegration   AnalyticsIntegration?
  discountRules          DiscountRule[]
  orderNotifications     OrderNotification[]
  goals                  Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan])
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
  AGENCY
}

model Subscription {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  plan      Plan
  status    String // active, cancelled, expired, paused
  startDate DateTime
  endDate   DateTime?

  razorpaySubscriptionId String?
  razorpayOrderId        String?
  razorpayPaymentId      String?
  razorpaySubId          String? // Alias

  amount   Int // in paise (cents)
  currency String @default("INR")
  interval String // monthly, yearly

  // Period tracking
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  cancelledBy        String?

  // Metadata
  metadata Json?

  // Payment method
  paymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([status])
}

// ==================== CONTACTS & CRM ====================

model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name        String
  phone       String?
  email       String?
  company     String?
  title       String?
  designation String?
  city        String?
  state       String?

  // Source tracking
  source   String  @default("manual") // whatsapp, indiamart, justdial, facebook, instagram, website
  sourceId String? // external ID from source

  // Pipeline
  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])
  stageId    String?
  stageName  String?

  // Tags & Custom Fields
  tags         String[] @default([])
  customFields Json? // { fieldId: value, ... }
  metadata     Json?

  // Deal value
  dealValue Float   @default(0)
  dealStage String? // for deal tracking

  // WhatsApp
  whatsappOptIn   Boolean   @default(false)
  whatsappBlocked Boolean   @default(false)
  emailOptIn      Boolean   @default(false)
  waProfilePic    String?
  waLastMessageAt DateTime?
  lastMessageAt   DateTime?
  lastActivity    DateTime?

  // Status
  status     String  @default("active") // active, inactive, blocked
  stage      String? // pipeline stage
  assignedTo String?

  // Relations
  activities           Activity[]
  appointments         Appointment[]
  documents            Document[]
  messages             Message[]
  orders               Order[]
  leadScores           LeadScore[]
  ledgerEntries        LedgerEntry[]
  scheduledMessages    ScheduledMessage[]
  dripQueueItems       DripQueue[]
  cartRecoveries       CartRecovery[]
  appointmentReminders AppointmentReminder[]
  loyaltyPoints        LoyaltyPoints[]
  callLogs             CallLog[]
  referredBy           Referral[]             @relation("Referrer")
  referredUsers        Referral[]             @relation("Referee")
  aiFollowUps          AIFollowUp[]
  supportTickets       SupportTicket[]
  productReviews       ProductReview[]
  wishlists            Wishlist[]
  stockAlerts          StockAlert[]
  addresses            CustomerAddress[]
  subscriptions        CustomerSubscription[]
  returnRequests       ReturnRequest[]
  segmentMembers       SegmentMember[]
  pushSubscriptions    PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, phone])
  @@unique([businessId, email])
  @@index([businessId])
  @@index([businessId, source])
  @@index([businessId, createdAt])
  @@index([businessId, lastMessageAt])
  @@index([source])
  @@index([tags])
}

model Pipeline {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name        String
  description String?
  stages      Stage[]
  contacts    Contact[]
  isDefault   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

model Stage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name  String
  order Int
  color String? // hex color

  @@index([pipelineId])
}

model Activity {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  type        String // call, email, whatsapp, meeting, note, task, deal_stage_change
  title       String
  description String?
  content     String? // Alternative field for content
  metadata    Json? // For storing specific data

  // Task fields
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("medium") // low, medium, high

  // Related to
  dealValue Float?
  stageFrom String?
  stageTo   String?

  createdBy String
  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, type])
  @@index([businessId, createdAt])
  @@index([contactId])
  @@index([type])
}

// ==================== WHATSAPP MESSAGING ====================

model Message {
  id         String   @id @default(cuid())
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  businessId String?

  waMessageId String? // WhatsApp message ID
  direction   String // incoming, outgoing
  type        String // text, image, document, template, location, button, list, etc.
  content     String // message text or caption
  mediaUrl    String? // For media messages
  mediaType   String? // image, document, video, audio
  mediaSize   Int?
  mediaName   String?

  // Template
  templateName     String?
  templateLanguage String?
  templateParams   Json?
  templateVars     Json? // Alias for templateParams

  // Status
  status          String    @default("pending") // pending, sent, delivered, read, failed
  statusTimestamp DateTime? // Alias
  statusUpdatedAt DateTime?
  errorCode       String?
  errorMessage    String?
  error           String? // Alias

  // Campaign
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  // Interactive
  interactiveType String?
  metadata        Json? // Extra message metadata

  // Reply context
  replyToMessageId String?
  replyContext     Json?

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model MessageTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name       String
  language   String @default("en")
  category   String @default("UTILITY") // MARKETING, UTILITY, AUTHENTICATION
  components Json // WA template structure

  // Status
  status       String  @default("PENDING") // PENDING, APPROVED, REJECTED
  waTemplateId String? // WhatsApp's template ID
  waStatus     String? // WhatsApp's status

  // Usage
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([businessId, name])
}

// ==================== CAMPAIGNS ====================

model Campaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name   String
  type   String // whatsapp_broadcast, email, sms, social_media
  status String @default("draft") // draft, scheduled, running, paused, completed, cancelled

  // Target
  segmentId      String?
  filters        Json? // { tags: [], source: [], pipelineId: "" }
  contactIds     String[] // For targeted campaigns
  targetTags     String[]
  targetFilters  Json?
  targetContacts Int      @default(0)
  targetCount    Int      @default(0)

  // Content
  templateId   String?
  templateName String?
  templateVars Json?
  content      Json // { text: "", buttons: [], media: {} }
  dripSteps    Json?

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  sentAt      DateTime?
  completedAt DateTime?

  // Stats
  totalContacts  Int @default(0)
  totalSent      Int @default(0)
  sent           Int @default(0)
  delivered      Int @default(0)
  read           Int @default(0)
  clicked        Int @default(0)
  failed         Int @default(0)
  totalDelivered Int @default(0)
  totalRead      Int @default(0)
  totalReplied   Int @default(0)
  totalFailed    Int @default(0)

  // Relations
  messages       Message[]
  dripQueueItems DripQueue[]

  // Error tracking
  errors Json[] // [{ contactId, error, timestamp }]

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
  @@index([businessId, status])
}

// ==================== APPOINTMENTS ====================

model Appointment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  title       String
  description String?
  service     String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("pending") // pending, confirmed, cancelled, completed, no_show

  // Location
  location    String?
  isOnline    Boolean @default(false)
  meetingLink String?
  meetingUrl  String?

  // Reminders
  reminderSent Boolean @default(false)

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([contactId])
  @@index([startTime])
  @@index([businessId, status])
  @@index([contactId, startTime])
}

// ==================== E-COMMERCE ====================

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name           String
  description    String?
  price          Float
  compareAtPrice Float?
  sku            String?
  barcode        String?

  // Inventory
  quantity       Int     @default(0)
  trackInventory Boolean @default(true)

  // Images
  images    String[]
  mainImage String?

  // Categorization
  category String?
  tags     String[]

  // Status
  isActive Boolean @default(true)
  status   String  @default("active") // active, draft, out_of_stock

  // External IDs
  shopifyId     String?
  wooCommerceId String?

  // Relations
  variants         ProductVariant[]
  orders           OrderItem[]
  cartItems        CartItem[]
  reviews          ProductReview[]
  wishlist         Wishlist[]
  stockAlerts      StockAlert[]
  bundleItems      BundleItem[]
  subscriptionPlan SubscriptionPlan?
  productVideos    ProductVideo[]
  priceHistory     PriceHistory[]
  recentlyViewed   RecentlyViewed[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  LowStockAlert LowStockAlert[]

  @@index([businessId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name     String // e.g., "Red - Large"
  options  Json // { color: "red", size: "L" }
  price    Float?
  sku      String?
  quantity Int     @default(0)

  @@index([productId])
}

model Order {
  id         String @id @default(cuid())
  businessId String

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  orderNumber   String @unique
  status        String @default("pending") // pending, processing, shipped, delivered, cancelled, refunded
  paymentStatus String @default("pending") // pending, paid, failed, refunded

  // Totals
  subtotal       Float
  taxAmount      Float @default(0)
  shippingAmount Float @default(0)
  discountAmount Float @default(0)
  total          Float

  // Items
  items OrderItem[]

  bundleId      String?
  bundle        ProductBundle? @relation(fields: [bundleId], references: [id])
  returnRequest ReturnRequest?

  // Shipping
  shippingAddress Json?

  // Gateway
  gateway     String? // razorpay, cod, etc.
  gatewayData Json? // raw payment data

  // Notes
  notes String?

  // Notifications
  orderNotifications OrderNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([contactId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  variantId String?

  name     String // snapshot at time of order
  quantity Int
  price    Float
  total    Float

  @@index([orderId])
}

// ==================== CART ====================

model Cart {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  contactId  String // user or contact id

  status String @default("active") // active, checked_out, abandoned

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, contactId])
  @@index([businessId])
  @@index([contactId])
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId    String?
  variantName  String?
  variantPrice Float?

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
}

// ==================== PRODUCT REVIEWS ====================

model ProductReview {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])

  customerName  String
  customerEmail String?
  rating        Int // 1-5
  title         String?
  comment       String?
  isVerified    Boolean @default(false) // purchased product
  isApproved    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([businessId])
  @@index([rating])
}

// ==================== WISHLIST ====================

model Wishlist {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  contactId  String
  contact    Contact? @relation(fields: [contactId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contactId, productId])
  @@index([contactId])
  @@index([productId])
}

// ==================== STOCK ALERTS ====================

model StockAlert {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])

  customerEmail String?
  customerPhone String?
  status        String    @default("pending") // pending, notified, failed
  notifiedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([businessId])
  @@index([status])
}

// ==================== SHIPPING RULES ====================

model ShippingRule {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name            String
  minOrderAmount  Float    @default(0)
  maxOrderAmount  Float?
  shippingFee     Float    @default(0)
  freeAbove       Float? // free shipping above this amount
  pincodePrefixes String[] // e.g., ["400", "401"] for Mumbai
  states          String[] // e.g., ["Maharashtra", "Karnataka"]
  isActive        Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ==================== PRODUCT BUNDLES ====================

model ProductBundle {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name          String
  description   String?
  discountType  String  @default("percentage") // percentage, fixed
  discountValue Float   @default(0)
  isActive      Boolean @default(true)

  items  BundleItem[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model BundleItem {
  id        String        @id @default(cuid())
  bundleId  String
  bundle    ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Int           @default(1)

  @@index([bundleId])
  @@index([productId])
}

// ==================== FLASH SALES ====================

model FlashSale {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  name          String
  discountType  String   @default("percentage") // percentage, fixed
  discountValue Float
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean  @default(true)
  productIds    String[] // products on sale

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([startsAt, endsAt])
}

// ==================== GIFT CARDS ====================

model GiftCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  code               String    @unique
  amount             Float
  balance            Float // remaining balance
  purchaserContactId String?
  recipientName      String?
  recipientEmail     String?
  recipientPhone     String?
  message            String?
  status             String    @default("active") // active, used, expired
  expiresAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([code])
  @@index([status])
}

// ==================== RECENTLY VIEWED ====================

