model LedgerEntry {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  date        DateTime   @default(now())
  type        LedgerType // income, expense
  category    String // Sales, Software, Salary, Marketing, etc.
