  maxReferrals   Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([businessId])
}

model Referral {
  id             String    @id @default(cuid())
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id])
  referrerId     String
  referrer       Contact?  @relation("Referrer", fields: [referrerId], references: [id])
  refereeId      String?
  referee        Contact?  @relation("Referee", fields: [refereeId], references: [id])
  referralCode   String    @unique
  status         String    @default("pending") // pending, completed, rewarded
  referrerReward Float     @default(0)
  refereeReward  Float     @default(0)
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([businessId])
  @@index([referrerId])
  @@index([referralCode])
}

// ==================== AI SALES AGENT ====================
model AIFollowUp {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  contactId   String
  contact     Contact?  @relation(fields: [contactId], references: [id])
  triggerType String // no_reply, deal_stale, payment_pending, appointment_missed
  channel     String    @default("whatsapp")
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("pending") // pending, sent, cancelled
  response    String?
  nextAction  String? // follow_up, escalate, close
  createdAt   DateTime  @default(now())

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
}

// ==================== WHATSAPP CATALOG ====================
model WhatsAppCatalog {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  productId    String
  name         String
  description  String
  price        Float
  currency     String   @default("INR")
  imageUrl     String?
  category     String?
  availability String   @default("in_stock") // in_stock, out_of_stock, preorder
  link         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
  @@index([productId])
}

// ==================== VIDEO MEETINGS ====================
model VideoMeeting {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  title        String
  description  String?
  meetingUrl   String
  meetingId    String
  platform     String   @default("jitsi") // jitsi, google_meet, zoom
  scheduledAt  DateTime
  duration     Int      @default(30) // minutes
  status       String   @default("scheduled") // scheduled, live, completed, cancelled
  hostId       String?
  participants String[]
  recordingUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
  @@index([scheduledAt])
  @@index([status])
}

// ==================== SUPPORT TICKETS ====================
model SupportTicket {
  id            String        @id @default(cuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id])
  ticketNumber  String        @unique // e.g., #TICKET-001
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  name          String
  email         String?
  phone         String?
  subject       String
  description   String
  category      String        @default("general") // general, billing, technical, feature_request, bug
  priority      String        @default("medium") // low, medium, high, urgent
  status        String        @default("open") // open, in_progress, waiting, resolved, closed
  assignedTo    String?
  tags          String[]
  attachments   String[] // file URLs
  internalNotes String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  resolvedAt    DateTime?
  closedAt      DateTime?
  replies       TicketReply[]

  @@index([businessId])
  @@index([ticketNumber])
  @@index([status])
  @@index([priority])
  @@index([contactId])
}

model TicketReply {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType  String // customer, agent, system
  senderId    String?
  senderName  String
  message     String
  attachments String[]
  isInternal  Boolean       @default(false) // internal notes not visible to customer
  createdAt   DateTime      @default(now())

  @@index([ticketId])
}

// ==================== VOICE AI (DOGRAH) ====================

model CallLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])

  dograhRunId  String? @unique
  workflowId   Int?
  workflowName String?

  direction    String // "inbound" | "outbound"
  status       String  @default("completed") // ringing, active, completed, failed, missed
  callType     String  @default("phone") // "phone" | "browser"
  callerNumber String
  calleeNumber String?

  duration      Int     @default(0) // seconds
  recordingUrl  String?
  transcript    String?
  transcriptUrl String?

  costInfo        Json?
  gatheredContext Json?
  annotations     Json?

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  walletTransactions WalletTransaction[]

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, createdAt])
  @@index([dograhRunId])
}


// ==================== CRM GOALS ====================
model Goal {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  title      String
  type       String   // revenue, deals, leads, calls, meetings
  target     Float
  current    Float    @default(0)
  period     String   @default("monthly") // daily, weekly, monthly, quarterly, yearly
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, type])
  @@index([businessId, isActive])
}

// ==================== WALLET & BILLING ====================

model Wallet {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id])

  balance  Float  @default(0) // Current balance in INR
  currency String @default("INR")

  // Limits
  lowBalanceThreshold Float @default(50) // Alert when below this

  // Stats
  totalRecharged  Float @default(0)
  totalSpent      Float @default(0)
  totalMarginPaid Float @default(0) // 10% margin to platform

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@index([businessId])
}

model WalletTransaction {
  id         String @id @default(cuid())
  walletId   String
  wallet     Wallet @relation(fields: [walletId], references: [id])
  businessId String // Denormalized for fast queries

  type    String // "recharge" | "call_deduction" | "refund" | "adjustment"
  amount  Float // Positive = credit, Negative = debit
  balance Float // Balance after this transaction

  // For call deductions
  callLogId String?
  callLog   CallLog? @relation(fields: [callLogId], references: [id])

  // Details
  description String
  metadata    Json? // Twilio cost, duration, phone number, etc.

  // Payment details (for recharges)
  razorpayOrderId   String?
  razorpayPaymentId String?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([type])
}

model PlatformEarning {
  id          String @id @default(cuid())
  businessId  String // Which business generated this
  walletTxnId String // Related wallet transaction

  twilioCost     Float // Original Twilio charge
  platformMargin Float // Your 10% cut
  totalCharged   Float // What customer paid

  type      String // "call_margin" | "sms_margin"
  callLogId String?

  status    String    @default("pending") // pending, settled
  settledAt DateTime?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([createdAt])
  @@index([status])
}

// ==================== AFFILIATE / REFERRAL SYSTEM (Platform-level) ====================

model PlatformReferral {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  referralCode  String   @unique
  totalReferrals Int     @default(0)
  totalEarnings  Float   @default(0)
  pendingPayout  Float   @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rewards       PlatformReferralReward[]
  payouts       PlatformReferralPayout[]

  @@index([referralCode])
}

model PlatformReferralReward {
  id            String   @id @default(cuid())
  referrerId    String   // Who referred
  refereeId     String   // Who was referred
  referralId    String
  referral      PlatformReferral @relation(fields: [referralId], references: [id])
  rewardType    String   // "signup" | "subscription" | "usage"
  rewardAmount  Float
  currency      String   @default("INR")
  status        String   @default("pending") // pending, credited, expired
  creditedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([referrerId])
  @@index([refereeId])
  @@index([status])
}

model PlatformReferralPayout {
  id            String   @id @default(cuid())
  referralId    String
  referral      PlatformReferral @relation(fields: [referralId], references: [id])
  amount        Float
  method        String   // "bank_transfer" | "upi" | "credit"
  status        String   @default("pending") // pending, processing, completed, failed
  transactionId String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([referralId])
  @@index([status])
}
